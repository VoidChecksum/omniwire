    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/picomatch": "^4.0.2",
    "@types/ssh2": "^1.15.0",
