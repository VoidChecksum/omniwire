{
  "name": "omniwire",
  "version": "2.2.0",
  "description": "Unified mesh control layer — 30-tool MCP server for managing SSH nodes, file transfers, and config sync across distributed infrastructure",
  "type": "module",
  "license": "MIT",
  "author": "VoidChecksum",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VoidChecksum/omniwire.git"
  },
  "homepage": "https://github.com/VoidChecksum/omniwire#readme",
  "bugs": {
    "url": "https://github.com/VoidChecksum/omniwire/issues"
  },
  "keywords": [
    "mcp",
    "mesh",
    "ssh",
    "terminal",
    "remote-execution",
    "file-transfer",
    "model-context-protocol",
    "infrastructure",
    "devops",
    "ai-tools",
    "claude",
    "wireguard"
  ],
  "bin": {
    "omniwire": "./dist/index.js",
    "ow": "./dist/index.js"
  },
  "main": "./dist/mcp/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp/index.js --stdio",
    "mcp:sse": "node dist/mcp/index.js",
    "dev": "tsc --watch",
    "sync": "node dist/sync/index.js",
    "sync:once": "node dist/sync/index.js --once",
    "sync:ingest": "node dist/sync/index.js --ingest-only"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.0",
    "@noble/ciphers": "^1.2.1",
    "pg": "^8.13.0",
    "picomatch": "^4.0.3",
    "ssh2": "^1.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/picomatch": "^4.0.2",
    "@types/ssh2": "^1.15.0",
    "typescript": "^5.7.0"
  }
}
